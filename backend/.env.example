# GuerillaGenics Backend — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env.

# ── Google Cloud ──────────────────────────────────────────────────────────────
GCP_PROJECT_ID=YOUR_GCP_PROJECT_ID_HERE
GCP_REGION=us-west1

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# ── The Odds API ──────────────────────────────────────────────────────────────
ODDS_API_KEY=YOUR_ODDS_API_KEY_HERE
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# ── OpenWeatherMap ────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY_HERE
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ── Slack (nightly ingest failure alerts) ────────────────────────────────────
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── API Security ──────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for internal/partner access
GG_API_KEYS=key1_replace_me,key2_replace_me

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,https://guerillagenics.app,https://www.guerillagenics.app

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_EXPENSIVE=10/minute

# ── App ───────────────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
PORT=8080

# ── Scraper Settings ─────────────────────────────────────────────────────────
SCRAPER_REQUEST_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_BACKOFF=2

# ── Formula Weights (can override defaults) ──────────────────────────────────
# Leave blank to use formula defaults defined in composite_futures.py
CFS_WEIGHT_ELO=
CFS_WEIGHT_NIR=
CFS_WEIGHT_SSC=
CFS_WEIGHT_IIS=
CFS_WEIGHT_MDI=
CFS_WEIGHT_PDS=
CFS_WEIGHT_EAF=
CFS_WEIGHT_MID=

# ── Monte Carlo ───────────────────────────────────────────────────────────────
MONTE_CARLO_SIMULATIONS=100000
